# ==========================================================================
# Sessions Marketplace — environment template
# Copy to `.env` and fill in real values:   cp .env.example .env
# docker-compose reads `.env` automatically.
# ==========================================================================

# ---------------------------- PostgreSQL ----------------------------------
POSTGRES_DB=sessions_marketplace
POSTGRES_USER=sessions_user
POSTGRES_PASSWORD=change_me_postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ------------------------------ Django ------------------------------------
DJANGO_SECRET_KEY=change_me_django_secret_key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,nginx
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:3000

# -------------------------------- JWT -------------------------------------
# Backend signs JWTs after GitHub OAuth. Keep this separate from the Django
# secret so tokens can be rotated independently.
JWT_SECRET_KEY=change_me_jwt_secret_key
JWT_ACCESS_TOKEN_LIFETIME_MIN=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# --------------------------- GitHub OAuth ---------------------------------
# Create at: GitHub > Settings > Developer settings > OAuth Apps
#   Homepage URL:               http://localhost
#   Authorization callback URL: http://localhost/api/auth/github/callback
GITHUB_OAUTH_CLIENT_ID=your_github_client_id
GITHUB_OAUTH_CLIENT_SECRET=your_github_client_secret
GITHUB_OAUTH_CALLBACK_URL=http://localhost/api/auth/github/callback
# Where the backend redirects the browser after OAuth (frontend SPA origin).
# It appends /auth/callback#access=...&refresh=...&role=...
FRONTEND_BASE_URL=http://localhost

# ------------------------ Razorpay (test mode) ----------------------------
# Dashboard > Settings > API Keys (use TEST mode keys).
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_test_key_secret

# ----------------------- MinIO (S3-compatible) ----------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio
MINIO_BUCKET=avatars
MINIO_ENDPOINT=http://minio:9000

# --- django-storages S3 backend (point at MinIO) ---
# These should mirror the MinIO root credentials and bucket above.
USE_S3=True
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=change_me_minio
AWS_STORAGE_BUCKET_NAME=avatars
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_S3_USE_SSL=False
# Public URL host for stored objects (browser-reachable MinIO API port).
AWS_S3_CUSTOM_DOMAIN=localhost:9000/avatars
AWS_QUERYSTRING_AUTH=False

# --------------------------- Rate limiting --------------------------------
THROTTLE_ANON=60/min
THROTTLE_USER=120/min

# ------------------------------ Frontend ----------------------------------
# Browser-side base URL for API calls. Goes through the nginx reverse proxy.
NEXT_PUBLIC_API_BASE_URL=http://localhost/api
